# ──────────────────────────────────────────────────────────────
# SRE Incident-Triage Agent — Environment Variables
# Copy to .env and fill in your values. Never commit .env!
# ──────────────────────────────────────────────────────────────

# --- LLM Provider (Groq — free tier, no credit card needed) ---
GROQ_API_KEY=your-groq-api-key-here

# --- Optional: LangSmith tracing (free tier, 5k traces/mo) ---
# LANGSMITH_API_KEY=your-langsmith-key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=sre-agent

# --- Docker Sandbox ---
# Default image for the sandbox container
SANDBOX_IMAGE=python:3.11-slim

# --- Break-o-matic target service ---
BREAKOMATIC_HOST=127.0.0.1
BREAKOMATIC_PORT=8099
